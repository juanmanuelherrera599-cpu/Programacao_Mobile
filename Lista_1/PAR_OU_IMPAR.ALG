Algoritmo "par_ou_impar"
// Descrição   : Le um número inteiro e informe se ele é par ou ímpar.
// Autor(a)    : Juan Manuel
// Data atual  : 26/02/2026
Var
 numero: inteiro
Inicio
escreva("Digite um número inteiro: ")
   leia(numero)

   se (numero % 2 = 0) entao
      escreval("O número é PAR")
   senao
      escreval("O número é ÍMPAR")
   fimse


Fimalgoritmo