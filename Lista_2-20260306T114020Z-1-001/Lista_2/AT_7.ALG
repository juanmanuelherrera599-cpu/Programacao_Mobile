algoritmo "AT_7"
 // NOME: JUAN MANUEL
//DATA: 05/03
//PROGRAMAÇĂO MOBILE

var
   num, limite, i, resultado: inteiro

inicio

   escreva("Digite o numero da tabuada: ")
   leia(num)

   escreva("Digite o limite final: ")
   leia(limite)

   para i de 1 ate limite faca
      resultado <- num * i
      escreval(num, " x ", i, " = ", resultado)
   fimpara

fimalgoritmo
